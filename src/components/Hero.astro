---
import ColorBends from "./ColorBends";
import NeuralNetwork from "./NeuralNetwork";
---

<section class="relative min-h-screen overflow-hidden pt-24">
	<!-- Background: ColorBends shader -->
	<div class="pointer-events-none absolute inset-0">
		<ColorBends
			client:load
			rotation={-16}
			speed={0.15}
			colors={["#6b10b8","#0a8f2a","#7a06c4"]}
			transparent
			autoRotate={1}
			scale={1.5}
			frequency={1}
			warpStrength={1}
			mouseInfluence={0.2}
			parallax={1.5}
			noise={0.1}
			className="!pointer-events-auto"
			style={{ width: '100%', height: '100%', position: 'absolute', inset: 0, opacity: 0.7 }}
		/>
	</div>

	<div class="relative mx-auto flex max-w-7xl flex-col-reverse items-center gap-12 px-6 py-20 lg:flex-row lg:gap-0 lg:py-34">
		<!-- Left: Copy -->
		<div class="flex flex-1 flex-col items-center text-center lg:items-start lg:text-left">
			<p
				class="mb-6 inline-flex items-center gap-2 rounded-full border border-neon/20 bg-neon/5 px-4 py-1.5 font-mono text-xs font-medium tracking-widest text-neon uppercase"
			>
				<span class="inline-block size-1.5 animate-glow-pulse rounded-full bg-neon"></span>
				Colectivo disruptivo
			</p>

			<h1
				class="font-heading text-4xl md:text-5xl leading-[0.95] font-black tracking-tight text-text sm:text-6xl lg:text-7xl xl:text-8xl"
			>
				<span class="sr-only">Agencia de Desarrollo Web, Marketing Digital y Diseño en México </span>
				TRANSFORMAMOS
				<br />
				IDEAS EN
				<br />
				<span class="text-neon">REALIDADES</span>
			</h1>

			<p class="mt-8 max-w-xl text-lg leading-relaxed text-muted sm:text-xl">
				Aplicamos soluciones tecnologicas y definimos ideas para convertirlas en
				realidades que potencian tu crecimiento.
			</p>

			<div class="mt-10 flex flex-wrap items-center gap-4">
				<a
					href="#contacto"
					class="group relative inline-flex items-center gap-2 rounded-lg bg-primary px-7 py-3.5 text-sm font-semibold tracking-wider text-text uppercase transition-all hover:bg-primary-hover hover:shadow-glow-primary"
				>
					Escríbenos
					<svg xmlns="http://www.w3.org/2000/svg" class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
					</svg>
				</a>
				<a
					href="#manifiesto"
					class="inline-flex items-center gap-2 rounded-lg border border-border px-7 py-3.5 text-sm font-semibold tracking-wider text-muted uppercase transition-all hover:border-text/30 hover:text-text"
				>
					Conoce nuestro impacto
				</a>
			</div>
		</div>

		<!-- Right: Neural network visualization -->
		<!-- <div class="relative flex-1">
			<div class="relative aspect-square w-full max-w-lg mx-auto lg:max-w-none">
				<NeuralNetwork client:visible />
				<!-- Glow orb behind
				<div
					class="pointer-events-none absolute top-1/2 left-1/2 -z-10 size-3/4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(57,255,20,0.06),transparent_70%)] blur-3xl"
				/>
			</div>
		</div> -->
	</div>

	<!-- Bottom fade -->
	<div
		class="pointer-events-none absolute bottom-0 left-0 h-32 w-full bg-gradient-to-t from-bg to-transparent"
	/>
</section>
