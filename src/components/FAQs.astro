---
import FAQSection from "./FAQSection";
---

<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": [
			{
				"@type": "Question",
				"name": "¿Están peleados con la IA?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "No, es un apoyo. Rechazamos las \"soluciones milagrosas\" sin base técnica. La IA es una herramienta poderosa cuando se usa con criterio y conocimiento, no un reemplazo de la ingeniería real."
				}
			},
			{
				"@type": "Question",
				"name": "¿Solo se dedican al desarrollo web?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "Somos un estudio integral. Diseñamos logotipos, brandbooks, estrategia técnica y digital, marketing. El desarrollo web es nuestro fuerte, pero nuestra visión abarca todo el ecosistema digital de tu proyecto."
				}
			},
			{
				"@type": "Question",
				"name": "¿Cuál es el precio?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "Cotizaciones personalizadas basadas en un análisis profundo de tus necesidades reales, sin paquetes genéricos. Cada proyecto es único y merece una propuesta que refleje exactamente lo que necesitas."
				}
			},
			{
				"@type": "Question",
				"name": "¿El primer acercamiento tiene costo?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "No. Creemos en el libre albedrío; escuchamos tu visión sin compromisos. La primera conversación es para entenderte, no para venderte."
				}
			}
		]
	}
</script>

<section id="faqs" class="relative py-26 lg:py-38">
	<div class="mx-auto max-w-3xl px-6">
		<div class="mb-14 text-center">
			<p
				class="mb-4 font-mono text-xs font-medium tracking-[0.3em] text-neon uppercase"
			>
				Preguntas frecuentes
			</p>
			<h2
				class="font-heading text-4xl font-black tracking-tight text-text sm:text-5xl lg:text-6xl"
			>
				RESOLVEMOS TUS DUDAS
			</h2>
		</div>

		<FAQSection client:visible />
	</div>
</section>
