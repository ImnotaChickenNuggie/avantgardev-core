---
import CursorWrapper from "../components/CursorWrapper";

interface Props {
	description?: string;
}

const {
	description = "Transformamos ideas en realidades. Colectivo disruptivo de diseño y desarrollo web.",
} = Astro.props;
---

<!doctype html>
<html lang="es-MX" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="keywords" content="avantgardev, desarrollo web, diseño web, innovación, tecnología, seo, marketing, diseño, ui, ux, web development, web design" />
		<meta name="author" content="Avantgardev" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		<!-- Google Fonts - Optimized loading -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<title>Avantgardev | Desarrollo, Marketing y Diseño Web a la medida para tu negocio | México</title>
	<link rel="canonical" href={Astro.url.href} />

	<!-- Open Graph -->
	<meta property="og:type" content="website" />
	<meta property="og:title" content="Avantgardev — Desarrollo Web de Vanguardia" />
	<meta property="og:description" content={description} />
	<meta property="og:image" content="https://avantgardev.com/og-image.png" />
	<meta property="og:url" content={Astro.url.href} />
	<meta property="og:locale" content="es_MX" />

	<!-- Twitter Cards -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="Avantgardev — Desarrollo Web de Vanguardia" />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content="https://avantgardev.com/og-image.png" />

	<!-- Organization Schema -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "Avantgardev",
			"url": "https://avantgardev.com",
			"description": "Colectivo disruptivo de diseño y desarrollo web",
			"logo": "https://avantgardev.com/logo.png"
		}
	</script>
	</head>
	<body>
		<CursorWrapper client:only="react" />
		<slot />
	</body>
</html>
