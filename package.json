{
  "name": "avantgardev",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check ./src",
    "lint:fix": "biome check --fix ./src",
    "format": "biome format --write ./src",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "gsap": "^3.14.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro}": [
      "biome check --fix --no-errors-on-unmatched"
    ],
    "*.{json,css}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
